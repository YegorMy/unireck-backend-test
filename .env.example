# api — environment configuration
#
# Copy to `.env` (gitignored) and adjust:  cp .env.example .env
# Every variable uses the `API_` prefix and is parsed + validated by the single
# Settings schema in app/core/config.py. Real environment variables take
# precedence over values in this file.

# --- App ---------------------------------------------------------------------
# Title shown by the FastAPI app.
API_PROJECT_NAME=api

# --- Database (PostgreSQL via docker-compose; async asyncpg driver) ----------
# Matches docker-compose.yml defaults (user/password/db = api). Leave empty to
# run without persistence (the schema bootstrap is skipped). Tests override this
# to in-memory SQLite, so no value is needed for `uv run pytest`.
API_DATABASE_URL=postgresql+asyncpg://api:api@localhost:5432/api
# Echo SQL statements to logs (debugging only).
API_DATABASE_ECHO=false

# --- LLM provider ------------------------------------------------------------
# Which provider to use:
#   fake   -> default; steerable canned output, needs no API key
#   kimi   -> real Moonshot/Kimi API (set API_KIMI_API_KEY below)
#   openai -> reserved, not implemented yet
API_LLM_PROVIDER=fake
# Steer the FakeProvider's canned output (only used when LLM_PROVIDER=fake):
# valid | malformed_json | missing_field | invalid_severity | provider_error
API_FAKE_PROVIDER_MODE=valid

# --- Kimi / Moonshot provider (only used when LLM_PROVIDER=kimi) --------------
# Get a key at https://platform.moonshot.ai/ (global) and paste it here.
API_KIMI_API_KEY=
# OpenAI-compatible base URL. Global: api.moonshot.ai ; China: api.moonshot.cn
API_KIMI_BASE_URL=https://api.moonshot.ai/v1
# Model id. Default moonshot-v1-8k is fast and well-suited to extraction.
# Options: moonshot-v1-8k | moonshot-v1-128k | kimi-k2.5 | kimi-k2.6 (thinking,
# slower — raise API_KIMI_TIMEOUT and leave API_KIMI_TEMPERATURE unset).
API_KIMI_MODEL=moonshot-v1-8k
# Sampling temperature (0-1). Leave UNSET (omitted) for thinking models like
# kimi-k2.6/k2.7 — they only accept their fixed default. Set it only for the
# moonshot-v1-* models, where lower is more deterministic for extraction.
# API_KIMI_TEMPERATURE=0.2
# Max tokens to generate (raise if JSON output is truncated).
API_KIMI_MAX_TOKENS=2048
# HTTP timeout in seconds for the provider call.
API_KIMI_TIMEOUT=30.0

# --- Auth --------------------------------------------------------------------
# Shared secret required in the `X-API-Key` header on every /v1/briefs/* route.
# An empty value makes those routes return 500 ("API key not configured").
API_API_KEY=dev-secret-change-me

# --- CORS (for the Chrome MV3 extension consumer) ----------------------------
# Origins allowed by the browser. The unpacked extension ID is dynamic, so a
# regex scoped to the chrome-extension scheme is used (never a blanket `*`).
# The default in code is empty (production-safe); set this for local e2e demos.
API_CORS_ALLOW_ORIGIN_REGEX=chrome-extension://.*
# Lists are JSON arrays; booleans are true/false.
API_CORS_ALLOW_METHODS=["GET","POST","OPTIONS"]
API_CORS_ALLOW_HEADERS=["Content-Type","X-API-Key"]
API_CORS_ALLOW_CREDENTIALS=false
